parameters:
    level: 5
    paths:
        - src
        - config
    tmpDir: build/phpstan

    # Allow arbitrary content/style JSON array shapes (user-defined schemas)
    treatPhpDocTypesAsCertain: false

    # Exclude config/ blade-like view references — they are documented
    # but not loadable at static-analysis time without a full Laravel app.
    excludePaths:
        - config/visual-builder.php

    # Traits are analysed via their using classes. In a standalone package
    # with no host app, traits (HasVisualBuilder) appear unused until a
    # consumer class uses them — this rule pattern silences only that
    # specific message.
    ignoreErrors:
        -
            message: '#is used zero times and is not analysed#'
            identifier: trait.unused
